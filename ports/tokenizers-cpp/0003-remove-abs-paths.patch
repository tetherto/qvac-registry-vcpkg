+  DESTINATION lib/cmake/tokenizers_cpp
+)
diff --git a/cmake/tokenizers_cpp-config-tokenizers_c-link.cmake.in b/cmake/tokenizers_cpp-config-tokenizers_c-link.cmake.in
new file mode 100644
index 0000000..322824d
--- /dev/null
+++ b/cmake/tokenizers_cpp-config-tokenizers_c-link.cmake.in
@@ -0,0 +1,7 @@
+# Resolve tokenizers_c link to installed Rust library using relocatable path.
+# (The export writes a relative path which the linker treats as -l, causing -llib/...)
+if(TARGET tokenizers::tokenizers_c)
+  set_target_properties(tokenizers::tokenizers_c PROPERTIES
+    INTERFACE_LINK_LIBRARIES "${_IMPORT_PREFIX}/lib/@TOKENIZERS_RUST_LIB_FILENAME@;@TOKENIZERS_C_LINK_LIBS_STR@"
+  )
+endif()
