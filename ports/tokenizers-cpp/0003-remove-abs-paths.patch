+# Config snippet to fix tokenizers_c INTERFACE_LINK_LIBRARIES so the Rust lib
+# path resolves via _IMPORT_PREFIX (avoids -llib/libtokenizers_c.a and works with vcpkg)
+list(JOIN TOKENIZERS_C_LINK_LIBS ";" TOKENIZERS_C_LINK_LIBS_STR)
+configure_file(
+  ${TOKENIZERS_CPP_ROOT}/cmake/tokenizers_cpp-config-tokenizers_c-link.cmake.in
+  ${CMAKE_CURRENT_BINARY_DIR}/tokenizers_cpp-config-tokenizers_c-link.cmake
+  @ONLY
+)
+
