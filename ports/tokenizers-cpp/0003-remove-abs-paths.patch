 set(TOKENIZERS_CPP_INCLUDE ${TOKENIZERS_CPP_ROOT}/include)
 
 # Find cargo executable
@@ -193,7 +194,12 @@ if (MLC_ENABLE_SENTENCEPIECE_TOKENIZER STREQUAL "ON")
