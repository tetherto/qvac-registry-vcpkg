diff --git a/CMakeLists.txt b/CMakeLists.txt
index d1a8c81..6466df2 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -11,7 +11,16 @@ endif()
 set(CMAKE_CXX_STANDARD 11)
 
 if(MSVC)
-  add_compile_options(/W4 /WX)
+  # Check if using clang-cl
+  if(CMAKE_CXX_COMPILER_ID MATCHES "Clang")
+    # Don't use /WX with clang-cl as it treats valid warnings as errors
+    add_compile_options(/W4 -Wno-error=unused-command-line-argument)
+    set(IS_CLANG_CL TRUE)
+  else()
+    add_compile_options(/W4 /WX)
+    # MSVC: avoid failing the build due to C4702 "unreachable code" under /WX
+    add_compile_options(/wd4702)
+  endif()
 else()
   add_compile_options(-Wall -Wextra -pedantic -Werror -Wno-unknown-pragmas)
   if (COMPILE_WASM)
