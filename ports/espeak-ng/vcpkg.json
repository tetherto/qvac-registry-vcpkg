{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "espeak-ng",
  "version": "1.52.0",
  "port-version": 1,
  "description": "eSpeak NG is an open source speech synthesizer that supports more than hundred languages and accents",
  "homepage": "https://github.com/espeak-ng/espeak-ng",
  "license": "GPL-3.0-or-later",
  "dependencies": [
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    }
  ],
  "features": {
    "async": {
      "description": "Support asynchronous speech synthesis"
    },
    "klatt": {
      "description": "Use klatt for speech synthesis"
    },
    "libpcaudio": {
      "description": "Use libPcAudio for sound output"
    },
    "libsonic": {
      "description": "Use libsonic for faster speech rates"
    },
    "mbrola": {
      "description": "Use mbrola for speech synthesis"
    },
    "speechplayer": {
      "description": "Use speech-player for speech synthesis"
    }
  }
}
