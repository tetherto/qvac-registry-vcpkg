diff --git a/cmake/CMakeLists.txt b/cmake/CMakeLists.txt
index 5e68990..0f3908c 100644
--- a/cmake/CMakeLists.txt
+++ b/cmake/CMakeLists.txt
@@ -1338,6 +1338,8 @@ function(onnxruntime_add_shared_library target_name)
         target_compile_definitions(${target_name} PRIVATE VER_MAJOR=${VERSION_MAJOR_PART})
         target_compile_definitions(${target_name} PRIVATE VER_MINOR=${VERSION_MINOR_PART})
         target_compile_definitions(${target_name} PRIVATE VER_BUILD=${VERSION_BUILD_PART})
+        # Undefine VER_PRIVATE first, then redefine it
+        target_compile_options(${target_name} PRIVATE "/UVER_PRIVATE")
         target_compile_definitions(${target_name} PRIVATE VER_PRIVATE=${VERSION_PRIVATE_PART})
         target_compile_definitions(${target_name} PRIVATE VER_STRING=\"${VERSION_STRING}\")
   endif()
@@ -1359,6 +1361,8 @@ function(onnxruntime_add_shared_library_module target_name)
         target_compile_definitions(${target_name} PRIVATE VER_MAJOR=${VERSION_MAJOR_PART})
         target_compile_definitions(${target_name} PRIVATE VER_MINOR=${VERSION_MINOR_PART})
         target_compile_definitions(${target_name} PRIVATE VER_BUILD=${VERSION_BUILD_PART})
+        # Undefine VER_PRIVATE first, then redefine it
+        target_compile_options(${target_name} PRIVATE "/UVER_PRIVATE")
         target_compile_definitions(${target_name} PRIVATE VER_PRIVATE=${VERSION_PRIVATE_PART})
         target_compile_definitions(${target_name} PRIVATE VER_STRING=\"${VERSION_STRING}\")
     endif()
@@ -1736,6 +1740,16 @@ if(VERSION_MAJOR_PART STREQUAL "0" AND VERSION_MINOR_PART STREQUAL "0" AND VERSI
     set(VERSION_STRING ${ORT_VERSION})
 endif()
 
+if (WIN32)
+add_compile_definitions(VER_MAJOR=${VERSION_MAJOR_PART})
+add_compile_definitions(VER_MINOR=${VERSION_MINOR_PART})
+add_compile_definitions(VER_BUILD=${VERSION_BUILD_PART})
+# Undefine VER_PRIVATE first, then redefine it to avoid Windows SDK conflict
+add_compile_options("/UVER_PRIVATE")
+add_compile_definitions(VER_PRIVATE=${VERSION_PRIVATE_PART})
+add_compile_definitions(VER_STRING=\"${VERSION_STRING}\")
+endif()
+
 
 if (WIN32)
   if (onnxruntime_USE_MIMALLOC)
