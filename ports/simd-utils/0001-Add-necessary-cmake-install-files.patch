diff --git a/CMakeLists.txt b/CMakeLists.txt
new file mode 100644
index 0000000..fdeb962
--- /dev/null
+++ b/CMakeLists.txt
@@ -0,0 +1,47 @@
+cmake_minimum_required(VERSION 3.12)
+
+project(simd_utils VERSION 1.0.0)
+
+include(GNUInstallDirs)
+include(CMakePackageConfigHelpers)
+
+add_library(simid_utils INTERFACE)
+
+target_include_directories(simid_utils
+  INTERFACE
+    $<BUILD_INTERFACE:${CMAKE_CURRENT_LIST_DIR}>
+    $<INSTALL_INTERFACE:${CMAKE_INSTALL_INCLUDEDIR}>
+)
+
+# Install headers (header-only library)
+install(
+  TARGETS simid_utils
+  EXPORT simd_utils_Targets
+  ARCHIVE DESTINATION ${CMAKE_INSTALL_LIBDIR}
+  LIBRARY DESTINATION ${CMAKE_INSTALL_LIBDIR}
+  RUNTIME DESTINATION ${CMAKE_INSTALL_BINDIR})
+
+write_basic_package_version_file("simd_utilsConfigVersion.cmake"
+                                VERSION ${PROJECT_VERSION}
+                                COMPATIBILITY SameMajorVersion)
+
+configure_package_config_file(
+    "${PROJECT_SOURCE_DIR}/simd_utilsConfig.cmake.in"
+    "${PROJECT_BINARY_DIR}/simd_utilsConfig.cmake"
+    INSTALL_DESTINATION
+    ${CMAKE_INSTALL_DATAROOTDIR}/simd_utils/cmake)
+
+install(EXPORT simd_utils_Targets
+    FILE simd_utilsTargets.cmake
+    NAMESPACE simd_utils::
+    DESTINATION ${CMAKE_INSTALL_DATAROOTDIR}/simd_utils/)
+
+install(FILES "${PROJECT_BINARY_DIR}/simd_utilsConfig.cmake"
+    "${PROJECT_BINARY_DIR}/simd_utilsConfigVersion.cmake"
+    DESTINATION ${CMAKE_INSTALL_DATAROOTDIR}/simd_utils/)
+
+install(DIRECTORY ${PROJECT_SOURCE_DIR}/ DESTINATION include/simd_utils 
+    PATTERN "*.h"
+    PATTERN "*/hpp"
+    PATTERN "*.hh"
+)
diff --git a/simd_utilsConfig.cmake.in b/simd_utilsConfig.cmake.in
new file mode 100644
index 0000000..ff0fa67
--- /dev/null
