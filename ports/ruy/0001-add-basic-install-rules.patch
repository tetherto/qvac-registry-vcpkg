diff --git a/CMakeLists.txt b/CMakeLists.txt
index 98d480d..9c84b31 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -40,9 +40,11 @@ include(cmake/ruy_cc_library.cmake)
 include(cmake/ruy_cc_binary.cmake)
 include(cmake/ruy_cc_test.cmake)
 
+find_package(cpuinfo REQUIRED CONFIG)
+
 # Skip cpuinfo if it was already generated, which can happen when ruy is
 # a subdirectory in a wider project that already uses cpuinfo.
-if (NOT TARGET cpuinfo)
+if (NOT TARGET cpuinfo::cpuinfo)
   # Test if the third_party/cpuinfo submodule was checked out before
   # adding that subdirectory, so we can do more helpful things below in the
   # else() block when it's not.
@@ -88,3 +90,45 @@ add_subdirectory("ruy")
 if (NOT RUY_MINIMAL_BUILD)
   add_subdirectory("example")
 endif()
+# --- Begin vcpkg install additions ---
+# Provide minimal install rules so ruy can be consumed as a package.
+
+# Make sure the public interface does not expose source-tree include paths.
+if (TARGET ruy)
+  target_include_directories(ruy INTERFACE
+    $<BUILD_INTERFACE:${CMAKE_CURRENT_SOURCE_DIR}/ruy>
+    $<INSTALL_INTERFACE:include>)
+endif()
+
+# Install headers (public includes are under the 'ruy' directory).
+install(
+  DIRECTORY "${CMAKE_CURRENT_SOURCE_DIR}/ruy/"
+  DESTINATION "include/ruy"
+  FILES_MATCHING
+    PATTERN "*.h"
+)
+
+# Collect all ruy-related targets so the export set is complete.
+set(ruy_export_targets "")
+get_property(_all_targets GLOBAL PROPERTY TARGETS)
+foreach(_t IN LISTS _all_targets)
+  if(_t MATCHES "^ruy")
+    list(APPEND ruy_export_targets "${_t}")
+  endif()
+endforeach()
+
+# Install and export all ruy targets.
+if(ruy_export_targets)
+  install(TARGETS ${ruy_export_targets}
+    EXPORT ruyTargets
+    ARCHIVE DESTINATION lib
+    LIBRARY DESTINATION lib
+    RUNTIME DESTINATION bin)
+endif()
+
+# Export all installed ruy targets (targets are added to this export from ruy_cc_library.cmake).
+install(EXPORT ruyTargets NAMESPACE ruy:: DESTINATION share/ruy)
+file(WRITE "${CMAKE_CURRENT_BINARY_DIR}/ruyConfig.cmake"
+  "include(CMakeFindDependencyMacro)\nfind_dependency(cpuinfo CONFIG)\ninclude(\"\\${CMAKE_CURRENT_LIST_DIR}/ruyTargets.cmake\")\n")
+install(FILES "${CMAKE_CURRENT_BINARY_DIR}/ruyConfig.cmake" DESTINATION share/ruy)
+# --- End vcpkg install additions ---
